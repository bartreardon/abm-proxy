# =============================================================================
# Jamf Pro Plugin – Configuration
# Copy to jamf.env and fill in your values.
# For multiple Jamf instances, copy this file to e.g. jamf_site2.env and
# copy jamf.py to jamf_site2.py — the server will load both automatically.
# =============================================================================

# Display name shown in the UI card header.
DISPLAY_NAME=Jamf Pro

# The ABM MDM server UUID for this Jamf instance.
# When set, this plugin is only queried for devices whose ABM assignedServer.id
# matches this value — preventing unnecessary calls to the wrong MDM instance.
# Leave empty to query all devices regardless of assigned server.
#
# Find the ID via:
#   GET /api/v1/proxy/mdmServers   →   response data[].id
ABM_SERVER_ID=

# Jamf Pro base URL (no trailing slash).
URL=https://your-instance.jamfcloud.com

# OAuth2 API client credentials.
# Create in Jamf Pro: Settings → API roles and clients
# Required read permissions: Computers (Read), Mobile Devices (Read)
CLIENT_ID=
CLIENT_SECRET=

# Cache TTL in minutes.
# Short window primarily to protect against rate limiting on repeated
# lookups of the same device within a short period.
CACHE_TTL_MINUTES=2
