# =============================================================================
# FleetDM Plugin – Configuration
# Copy to fleetdm.env and fill in your values.
# For multiple Fleet instances, copy both files to e.g. fleetdm_prod.env and
# copy fleetdm.py to fleetdm_prod.py — the server will load both automatically.
# =============================================================================

# Display name shown in the UI card header.
DISPLAY_NAME=FleetDM

# The ABM MDM server UUID for this Fleet instance.
# When set, this plugin is only queried for devices whose ABM assignedServer.id
# matches this value. Leave empty to query all devices regardless of assigned server.
#
# Find the ID via:
#   GET /api/v1/proxy/mdmServers   →   response data[].id
ABM_SERVER_ID=

# FleetDM base URL (no trailing slash).
URL=https://fleet.example.com

# Static API token.
# Generate in the Fleet UI: My account → Get API token (or visit /profile).
# Note: SSO/MFA users must retrieve the token from the UI — email/password login
# is disabled for those accounts.
API_TOKEN=

# Cache TTL in minutes.
# Short window primarily to protect against rate limiting on repeated
# lookups of the same device within a short period.
CACHE_TTL_MINUTES=2
