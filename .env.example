# =============================================================================
# ABM Proxy – Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Apple Business Manager OAuth2 credentials -------------------------------
# All four values are required for ABM API access.
# See README.md for instructions on obtaining these.

ABM_CLIENT_ID=your-client-id-here
ABM_TEAM_ID=your-team-id-here
ABM_KEY_ID=your-key-id-here

# Absolute path (or path relative to the working directory) to your EC private
# key PEM file.  E.g. /etc/abm-proxy/private_key.pem
ABM_PRIVATE_KEY_FILE=/path/to/private_key.pem

# --- Cache -------------------------------------------------------------------
# Directory where device JSON files are stored.
CACHE_DIR=./cache

# How long (in hours) a cached device record is considered fresh.
# Set to 0 to disable TTL (records only expire on explicit refresh).
CACHE_TTL_HOURS=24

# --- Server ------------------------------------------------------------------
HOST=0.0.0.0
PORT=5050
LOG_LEVEL=INFO

# Optional API key.  When set, all /api/* endpoints require the header
#   X-API-Key: <value>
# or the query parameter ?api_key=<value>.
# Leave blank to disable authentication (fine for private/internal use).
API_KEY=

# --- SOFA version feeds ------------------------------------------------------
SOFA_ENABLED=true
SOFA_FEED_URL=https://sofa.macadmins.io/v2/macos_data_feed.json
SOFA_IOS_FEED_URL=https://sofa.macadmins.io/v2/ios_data_feed.json
SOFA_CACHE_TTL_HOURS=6
